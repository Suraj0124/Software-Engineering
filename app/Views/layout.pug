html
  head
    title Nepali Hami – Guitar Learning Platform
    style.
      body { font-family: Arial, sans-serif; margin: 0; padding: 0; background: #f5f5f5; }
      nav { background: #2c3e50; padding: 15px 30px; }
      nav a { color: white; text-decoration: none; margin-right: 20px; font-size: 16px; }
      nav a:hover { color: #f39c12; }
      .container { max-width: 1100px; margin: 30px auto; padding: 0 20px; }
      .card { background: white; border-radius: 8px; padding: 20px; margin-bottom: 15px; box-shadow: 0 2px 5px rgba(0,0,0,0); }
      .card:hover { box-shadow: 0 4px 10px rgba(0,0,0,0.2); }
      a { color: #2c3e50; }
      h1 { color: #2c3e50; }
      .badge { display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: bold; }
      .badge-beginner { background: #d5f5e3; color: #1e8449; }
      .badge-intermediate { background: #fef9e7; color: #d4ac0d; }
      .badge-advanced { background: #fadbd8; color: #c0392b; }
      .btn { display: inline-block; padding: 8px 16px; background: #2c3e50; color: white; border-radius: 5px; text-decoration: none; }
      .btn:hover { background: #f39c12; color: white; }
      .nav-right { float: right; }
  body
    nav
      a(href="/") 🎸 Nepali Hami
      a(href="/lessons") Lessons
      a(href="/categories") Categories
      a(href="/users") Users
      if sessionUser
        a.nav-right(href="/logout") 👤 #{sessionUser.name} | Logout
      else
        a.nav-right(href="/register") Register
        a.nav-right(href="/login") Login
    .container
      block content