extends layout

block content
  .login-page
    .login-box
      .login-header
        span.login-logo 🎸
        h1 Welcome to Nepali Hami
        p.tagline The #1 Guitar Learning Platform for Everyone
        .welcome-features
          span.wf 🎵 Video Lessons
          span.wf 🥁 Practice Tools
          span.wf ⭐ Ratings
          span.wf 🎸 Chord Library

      .divider-line

      if error
        .error-msg ⚠️ #{error}

      form(method='POST' action='/login')
        .form-group
          label Email Address
          input(type='email' name='email' placeholder='Enter your email' required)
        .form-group
          label Password
          input(type='password' name='password' placeholder='Enter your password' required)
        .form-options
          a.forgot-link(href='/forgot') Forgot password?
        button.btn-login(type='submit') Sign In →

      .divider
        span OR

      .admin-box
        p.admin-title 🔑 Admin Access
        p.admin-desc Manage users and platform content.
        a.btn-admin(href='/admin-login') Login as Admin →

      p.register-link Don't have an account?
        a(href='/register') Register here

  style.
    body { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #2d6a4f 100%) !important; min-height: 100vh; }

    .login-page {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 90vh;
      padding: 2rem;
    }

    .login-box {
      background: white;
      border-radius: 20px;
      padding: 2.5rem;
      width: 100%;
      max-width: 450px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }

    .login-header { text-align: center; margin-bottom: 1.5rem; }
    .login-logo { font-size: 3.5rem; display: block; margin-bottom: 0.5rem; }
    .login-header h1 {
      font-size: 1.7rem;
      font-weight: 800;
      color: #1a1a2e;
      margin-bottom: 0.3rem;
    }
    .tagline {
      color: #2d6a4f;
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }

    .welcome-features {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 0.75rem;
    }
    .wf {
      background: #f0faf5;
      border: 1px solid #c6e8d4;
      color: #2d6a4f;
      padding: 0.3rem 0.7rem;
      border-radius: 20px;
      font-size: 0.78rem;
      font-weight: 600;
    }

    .divider-line {
      height: 1px;
      background: #e2e8f0;
      margin: 1.5rem 0;
    }

    .form-group { margin-bottom: 1.2rem; }
    .form-group label {
      display: block;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: #333;
      font-size: 0.9rem;
    }
    .form-group input {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 2px solid #e2e8f0;
      border-radius: 10px;
      font-size: 1rem;
      box-sizing: border-box;
      transition: border-color 0.2s;
    }
    .form-group input:focus {
      outline: none;
      border-color: #2d6a4f;
    }

    .form-options {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 1.2rem;
    }
    .forgot-link {
      color: #2d6a4f;
      font-size: 0.85rem;
      text-decoration: none;
      font-weight: 500;
    }

    .btn-login {
      width: 100%;
      background: linear-gradient(135deg, #1a1a2e, #2d6a4f);
      color: white;
      border: none;
      padding: 0.85rem;
      border-radius: 10px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-login:hover { opacity: 0.9; transform: translateY(-2px); }

    .error-msg {
      background: #fff5f5;
      border: 1px solid #fed7d7;
      color: #c53030;
      padding: 0.75rem 1rem;
      border-radius: 10px;
      margin-bottom: 1.2rem;
      font-size: 0.9rem;
    }

    .divider {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin: 1.5rem 0;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #e2e8f0;
    }
    .divider span { color: #aaa; font-size: 0.85rem; }

    .admin-box {
      background: #f8f9fa;
      border: 2px solid #e2e8f0;
      border-radius: 12px;
      padding: 1.2rem;
      text-align: center;
      margin-bottom: 1.5rem;
    }
    .admin-title { font-weight: 700; color: #1a1a2e; margin-bottom: 0.3rem; font-size: 1rem; }
    .admin-desc { font-size: 0.85rem; color: #666; margin-bottom: 1rem; }
    .btn-admin {
      display: block;
      background: #1a1a2e;
      color: white;
      padding: 0.7rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      transition: background 0.2s;
    }
    .btn-admin:hover { background: #2d6a4f; color: white; }

    .register-link {
      text-align: center;
      font-size: 0.9rem;
      color: #666;
      margin: 0;
    }
    .register-link a {
      color: #2d6a4f;
      font-weight: 600;
      text-decoration: none;
    }
