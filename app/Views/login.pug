extends layout

block content
  .login-container
    h1 🔐 Login
    if error
      .error-msg= error
    form(method='POST' action='/login')
      .form-group
        label Email
        input(type='email' name='email' required)
      .form-group
        label Password
        input(type='password' name='password' required)
      button.btn-login(type='submit') Login
    p.register-link Don't have an account? 
      a(href='/register') Register here

  style.
    .login-container { max-width: 400px; margin: 3rem auto; padding: 2rem; background: #fff; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
    h1 { text-align: center; color: #1a1a2e; margin-bottom: 1.5rem; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; font-weight: 600; margin-bottom: 0.4rem; color: #333; }
    .form-group input { width: 100%; padding: 0.6rem; border: 1px solid #ddd; border-radius: 8px; font-size: 1rem; box-sizing: border-box; }
    .btn-login { width: 100%; background: #1a1a2e; color: #fff; border: none; padding: 0.75rem; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer; margin-top: 0.5rem; }
    .btn-login:hover { background: #2b2d42; }
    .error-msg { background: #ffe0e0; color: #c00; padding: 0.75rem; border-radius: 8px; margin-bottom: 1rem; }
    .register-link { text-align: center; margin-top: 1rem; font-size: 0.9rem; }