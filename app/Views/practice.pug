    let rhythmBeatIndex = 0, rhythmPattern = [], rhythmInterval = null, rhythmLevel = 1;
    const rhythmScoreEl = document.getElementById('rhythm-score');
    const rhythmAccuracyEl = document.getElementById('rhythm-accuracy');
    const rhythmLevelEl = document.getElementById('rhythm-level');
    const rhythmPatternEl = document.getElementById('rhythm-pattern');
    const rhythmFeedback = document.getElementById('rhythm-feedback');
    const rhythmTapBtn = document.getElementById('rhythm-tap-btn');
    const rhythmStartBtn = document.getElementById('rhythm-start-btn');
    const rhythmStopBtn = document.getElementById('rhythm-stop-btn');
    function buildRhythmPattern() {
      rhythmPattern = rhythmPatterns[Math.floor(Math.random() * rhythmPatterns.length)]; rhythmPatternEl.innerHTML = '';
      rhythmPattern.forEach((beat, i) => { const box = document.createElement('div'); box.className = 'rhythm-beat-box'; box.id = 'rb' + i; box.textContent = beat === 1 ? '●' : '○'; rhythmPatternEl.appendChild(box); });
    }
    function rhythmTick() { document.querySelectorAll('.rhythm-beat-box').forEach(b => b.classList.remove('active')); const box = document.getElementById('rb' + rhythmBeatIndex); if (box) box.classList.add('active'); rhythmBeatIndex = (rhythmBeatIndex + 1) % rhythmPattern.length; }
    function handleRhythmTap() {
      if (!rhythmActive) return;
      const currentBeat = rhythmBeatIndex === 0 ? rhythmPattern.length - 1 : rhythmBeatIndex - 1;
      const box = document.getElementById('rb' + currentBeat); rhythmTotal++;
      if (rhythmPattern[currentBeat] === 1) {
        rhythmHits++; rhythmScore += 10 * rhythmLevel;
        if (box) { box.classList.add('hit'); setTimeout(() => box && box.classList.remove('hit'), 200); }
        rhythmFeedback.textContent = '✅ On beat!'; rhythmFeedback.style.color = '#2d6a4f';
      } else { rhythmFeedback.textContent = '❌ Off beat!'; rhythmFeedback.style.color = '#e63946'; }
      rhythmScoreEl.textContent = rhythmScore;
      rhythmAccuracyEl.textContent = Math.round((rhythmHits / rhythmTotal) * 100) + '%';
      if (rhythmTotal % 16 === 0) { rhythmLevel++; rhythmLevelEl.textContent = rhythmLevel; buildRhythmPattern(); }
    }
    rhythmTapBtn.addEventListener('click', handleRhythmTap);
    document.addEventListener('keydown', (e) => { if (e.code === 'Space' && rhythmActive) { e.preventDefault(); handleRhythmTap(); } });
    rhythmStartBtn.addEventListener('click', () => {
      rhythmActive = true; rhythmScore = 0; rhythmHits = 0; rhythmTotal = 0; rhythmBeatIndex = 0; rhythmLevel = 1;
      rhythmScoreEl.textContent = '0'; rhythmAccuracyEl.textContent = '0%'; rhythmLevelEl.textContent = '1';
      buildRhythmPattern(); rhythmInterval = setInterval(rhythmTick, 500);
      rhythmStartBtn.style.display = 'none'; rhythmStopBtn.style.display = 'inline-block';
      rhythmFeedback.textContent = 'Tap in time with the ● beats!';
    });
    rhythmStopBtn.addEventListener('click', () => {
      rhythmActive = false; clearInterval(rhythmInterval);
      rhythmStartBtn.style.display = 'inline-block'; rhythmStopBtn.style.display = 'none';
      rhythmFeedback.textContent = `Final Score: ${rhythmScore} | Accuracy: ${rhythmTotal > 0 ? Math.round((rhythmHits/rhythmTotal)*100) : 0}%`;
    });

    // ── FREE STRUM CHORD RECOGNISER ──
    const CHORD_FREQS = { 'E': 82.41, 'A': 110.00, 'D': 146.83, 'G': 196.00, 'B': 246.94, 'F': 174.61, 'Am': 110.00, 'Em': 82.41, 'Dm': 146.83 };
    let strumRunning = false, strumStream = null, strumAnalyser = null, strumCtx = null;
    let strumFrame = null, strumHistory = [], lastStrumTime = 0;
    const strumChordEl = document.getElementById('strum-chord');
    const strumFreqInfo = document.getElementById('strum-freq-info');
    const strumHistoryList = document.getElementById('strum-history-list');
    const strumStartBtn = document.getElementById('strum-start-btn');
    const strumStopBtn = document.getElementById('strum-stop-btn');
    function detectStrumChord() {
      if (!strumRunning) return;
      const buf = new Float32Array(strumAnalyser.fftSize); strumAnalyser.getFloatTimeDomainData(buf);
      const freq = autoCorrelate(buf, strumCtx.sampleRate); const now = Date.now();
      if (freq > 60 && freq < 400 && now - lastStrumTime > 1000) {
        let closest = 'E', minDiff = Infinity;
        Object.entries(CHORD_FREQS).forEach(([chord, f]) => { const diff = Math.abs(freq - f); if (diff < minDiff) { minDiff = diff; closest = chord; } });
        if (minDiff < 20) {
          lastStrumTime = now; strumChordEl.textContent = closest;
          strumFreqInfo.textContent = `Detected: ${freq.toFixed(1)} Hz`;
          strumHistory.unshift(closest); if (strumHistory.length > 8) strumHistory.pop();
          strumHistoryList.innerHTML = strumHistory.map(c => `<span class="strum-history-pill">${c}</span>`).join('');
        }
      }
      strumFrame = requestAnimationFrame(detectStrumChord);
    }
    strumStartBtn.addEventListener('click', async () => {
      try {
        strumCtx = new (window.AudioContext || window.webkitAudioContext)();
        strumStream = await navigator.mediaDevices.getUserMedia({ audio: true });
        const source = strumCtx.createMediaStreamSource(strumStream);
        strumAnalyser = strumCtx.createAnalyser(); strumAnalyser.fftSize = 2048; source.connect(strumAnalyser);
        strumRunning = true; strumHistory = []; strumChordEl.textContent = '--';
        strumFreqInfo.textContent = 'Listening... strum your guitar!';
        strumHistoryList.innerHTML = '<p class="strum-no-history">Waiting for guitar...</p>';
        strumStartBtn.style.display = 'none'; strumStopBtn.style.display = 'inline-block';
        detectStrumChord();
      } catch(e) { strumFreqInfo.textContent = '❌ Microphone access denied!'; }
    });
    strumStopBtn.addEventListener('click', () => {
      strumRunning = false; cancelAnimationFrame(strumFrame);
      if (strumStream) strumStream.getTracks().forEach(t => t.stop());
      strumStartBtn.style.display = 'inline-block'; strumStopBtn.style.display = 'none';
      strumChordEl.textContent = '--'; strumFreqInfo.textContent = 'Play your guitar...';
    });
