extends layout

block content
  .practice-container
    .practice-header
      h1 🎸 Practice Tools
      p Use our interactive tools to perfect your guitar playing

    .tools-grid

      //- ── METRONOME ──
      .tool-card
        .tool-header
          span.tool-icon 🥁
          h2 Metronome
        .tool-body
          .bpm-display
            span#bpm-value 80
            span.bpm-label BPM
          .control-group
            label Tempo
            input#bpm-slider(type="range" min="40" max="220" value="80")
            .range-labels
              span 40
              span 220
          .control-group
            label Volume
            input#metro-volume(type="range" min="0" max="100" value="80")
            span#metro-vol-label 80%
          .beat-dots
            .dot#dot1
            .dot#dot2
            .dot#dot3
            .dot#dot4
          button#metro-btn.start-btn ▶ Start
        .tool-footer
          p Adjust BPM and volume, then press Start

      //- ── LIVE PITCH DETECTOR ──
      .tool-card
        .tool-header
          span.tool-icon 🎤
          h2 Live Note Detector
        .tool-body
          .pitch-display
            .pitch-note#pitch-note --
            .pitch-cents#pitch-cents Play a string...
          .pitch-indicator
            .pitch-bar
              .pitch-needle#pitch-needle
            .pitch-labels
              span Flat ♭
              span In Tune ✓
              span Sharp ♯
          .pitch-status#pitch-status 🎤 Press Start to detect your note
          button#pitch-btn.start-btn 🎤 Start Listening
        .tool-footer
          p Play any string on your guitar and we will detect the note!

      //- ── GUITAR TUNER ──
      .tool-card
        .tool-header
          span.tool-icon 🎵
          h2 Guitar Tuner
        .tool-body
          p.tuner-hint Click a string to hear the reference note
          .strings-grid
            each string in [{note:'E2',label:'6th - Low E'},{note:'A2',label:'5th - A'},{note:'D3',label:'4th - D'},{note:'G3',label:'3rd - G'},{note:'B3',label:'2nd - B'},{note:'E4',label:'1st - High E'}]
              button.string-btn(data-note=string.note)
                span.string-note= string.note.replace('2','').replace('3','').replace('4','')
                span.string-label= string.label
          .control-group
            label Volume
            input#tuner-volume(type="range" min="0" max="100" value="80")
            span#tuner-vol-label 80%
        .tool-footer
          p Play each string on your guitar and match the sound

    //- ── CHORD LIBRARY ──
    .chord-section
      .chord-section-header
        h2 🎸 Chord Library
        p Learn the most common guitar chords — click any chord to see finger positions
      .chords-grid
        .chord-card(data-chord="G")
          .chord-name G
          svg.chord-diagram(viewBox="0 0 100 120")
            line(x1="10" y1="20" x2="90" y2="20" stroke="#333" stroke-width="3")
            line(x1="10" y1="40" x2="90" y2="40" stroke="#333" stroke-width="1")
            line(x1="10" y1="60" x2="90" y2="60" stroke="#333" stroke-width="1")
            line(x1="10" y1="80" x2="90" y2="80" stroke="#333" stroke-width="1")
            line(x1="10" y1="100" x2="90" y2="100" stroke="#333" stroke-width="1")
            line(x1="10" y1="20" x2="10" y2="100" stroke="#333" stroke-width="1")
            line(x1="26" y1="20" x2="26" y2="100" stroke="#333" stroke-width="1")
            line(x1="42" y1="20" x2="42" y2="100" stroke="#333" stroke-width="1")
            line(x1="58" y1="20" x2="58" y2="100" stroke="#333" stroke-width="1")
            line(x1="74" y1="20" x2="74" y2="100" stroke="#333" stroke-width="1")
            line(x1="90" y1="20" x2="90" y2="100" stroke="#333" stroke-width="1")
            circle(cx="10" cy="30" r="7" fill="#2d6a4f")
            circle(cx="42" cy="50" r="7" fill="#2d6a4f")
            circle(cx="90" cy="30" r="7" fill="#2d6a4f")
          .chord-fingers
            span 2-1-0-0-0-3
          .chord-label G Major

        .chord-card(data-chord="C")
          .chord-name C
          svg.chord-diagram(viewBox="0 0 100 120")
            line(x1="10" y1="20" x2="90" y2="20" stroke="#333" stroke-width="3")
            line(x1="10" y1="40" x2="90" y2="40" stroke="#333" stroke-width="1")
            line(x1="10" y1="60" x2="90" y2="60" stroke="#333" stroke-width="1")
            line(x1="10" y1="80" x2="90" y2="80" stroke="#333" stroke-width="1")
            line(x1="10" y1="100" x2="90" y2="100" stroke="#333" stroke-width="1")
            line(x1="10" y1="20" x2="10" y2="100" stroke="#333" stroke-width="1")
            line(x1="26" y1="20" x2="26" y2="100" stroke="#333" stroke-width="1")
            line(x1="42" y1="20" x2="42" y2="100" stroke="#333" stroke-width="1")
            line(x1="58" y1="20" x2="58" y2="100" stroke="#333" stroke-width="1")
            line(x1="74" y1="20" x2="74" y2="100" stroke="#333" stroke-width="1")
            line(x1="90" y1="20" x2="90" y2="100" stroke="#333" stroke-width="1")
            circle(cx="26" cy="30" r="7" fill="#2d6a4f")
            circle(cx="58" cy="50" r="7" fill="#2d6a4f")
            circle(cx="74" cy="30" r="7" fill="#2d6a4f")
            text(x="10" y="115" font-size="8" fill="#888") x
          .chord-fingers
            span x-3-2-0-1-0
          .chord-label C Major

        .chord-card(data-chord="D")
          .chord-name D
          svg.chord-diagram(viewBox="0 0 100 120")
            line(x1="10" y1="20" x2="90" y2="20" stroke="#333" stroke-width="3")
            line(x1="10" y1="40" x2="90" y2="40" stroke="#333" stroke-width="1")
            line(x1="10" y1="60" x2="90" y2="60" stroke="#333" stroke-width="1")
            line(x1="10" y1="80" x2="90" y2="80" stroke="#333" stroke-width="1")
            line(x1="10" y1="100" x2="90" y2="100" stroke="#333" stroke-width="1")
            line(x1="10" y1="20" x2="10" y2="100" stroke="#333" stroke-width="1")
            line(x1="26" y1="20" x2="26" y2="100" stroke="#333" stroke-width="1")
            line(x1="42" y1="20" x2="42" y2="100" stroke="#333" stroke-width="1")
            line(x1="58" y1="20" x2="58" y2="100" stroke="#333" stroke-width="1")
            line(x1="74" y1="20" x2="74" y2="100" stroke="#333" stroke-width="1")
            line(x1="90" y1="20" x2="90" y2="100" stroke="#333" stroke-width="1")
            circle(cx="58" cy="30" r="7" fill="#2d6a4f")
            circle(cx="74" cy="50" r="7" fill="#2d6a4f")
            circle(cx="90" cy="30" r="7" fill="#2d6a4f")
          .chord-fingers
            span x-x-0-2-3-2
          .chord-label D Major

        .chord-card(data-chord="Am")
          .chord-name Am
          svg.chord-diagram(viewBox="0 0 100 120")
            line(x1="10" y1="20" x2="90" y2="20" stroke="#333" stroke-width="3")
            line(x1="10" y1="40" x2="90" y2="40" stroke="#333" stroke-width="1")
            line(x1="10" y1="60" x2="90" y2="60" stroke="#333" stroke-width="1")
            line(x1="10" y1="80" x2="90" y2="80" stroke="#333" stroke-width="1")
            line(x1="10" y1="100" x2="90" y2="100" stroke="#333" stroke-width="1")
            line(x1="10" y1="20" x2="10" y2="100" stroke="#333" stroke-width="1")
            line(x1="26" y1="20" x2="26" y2="100" stroke="#333" stroke-width="1")
            line(x1="42" y1="20" x2="42" y2="100" stroke="#333" stroke-width="1")
            line(x1="58" y1="20" x2="58" y2="100" stroke="#333" stroke-width="1")
            line(x1="74" y1="20" x2="74" y2="100" stroke="#333" stroke-width="1")
            line(x1="90" y1="20" x2="90" y2="100" stroke="#333" stroke-width="1")
            circle(cx="26" cy="30" r="7" fill="#e63946")
            circle(cx="42" cy="50" r="7" fill="#e63946")
            circle(cx="58" cy="30" r="7" fill="#e63946")
          .chord-fingers
            span x-0-2-2-1-0
          .chord-label A Minor

        .chord-card(data-chord="Em")
          .chord-name Em
          svg.chord-diagram(viewBox="0 0 100 120")
            line(x1="10" y1="20" x2="90" y2="20" stroke="#333" stroke-width="3")
            line(x1="10" y1="40" x2="90" y2="40" stroke="#333" stroke-width="1")
            line(x1="10" y1="60" x2="90" y2="60" stroke="#333" stroke-width="1")
            line(x1="10" y1="80" x2="90" y2="80" stroke="#333" stroke-width="1")
            line(x1="10" y1="100" x2="90" y2="100" stroke="#333" stroke-width="1")
            line(x1="10" y1="20" x2="10" y2="100" stroke="#333" stroke-width="1")
            line(x1="26" y1="20" x2="26" y2="100" stroke="#333" stroke-width="1")
            line(x1="42" y1="20" x2="42" y2="100" stroke="#333" stroke-width="1")
            line(x1="58" y1="20" x2="58" y2="100" stroke="#333" stroke-width="1")
            line(x1="74" y1="20" x2="74" y2="100" stroke="#333" stroke-width="1")
            line(x1="90" y1="20" x2="90" y2="100" stroke="#333" stroke-width="1")
            circle(cx="42" cy="30" r="7" fill="#e63946")
            circle(cx="58" cy="30" r="7" fill="#e63946")
          .chord-fingers
            span 0-2-2-0-0-0
          .chord-label E Minor

        .chord-card(data-chord="F")
          .chord-name F
          svg.chord-diagram(viewBox="0 0 100 120")
            line(x1="10" y1="20" x2="90" y2="20" stroke="#333" stroke-width="3")
            line(x1="10" y1="40" x2="90" y2="40" stroke="#333" stroke-width="1")
            line(x1="10" y1="60" x2="90" y2="60" stroke="#333" stroke-width="1")
            line(x1="10" y1="80" x2="90" y2="80" stroke="#333" stroke-width="1")
            line(x1="10" y1="100" x2="90" y2="100" stroke="#333" stroke-width="1")
            line(x1="10" y1="20" x2="10" y2="100" stroke="#333" stroke-width="1")
            line(x1="26" y1="20" x2="26" y2="100" stroke="#333" stroke-width="1")
            line(x1="42" y1="20" x2="42" y2="100" stroke="#333" stroke-width="1")
            line(x1="58" y1="20" x2="58" y2="100" stroke="#333" stroke-width="1")
            line(x1="74" y1="20" x2="74" y2="100" stroke="#333" stroke-width="1")
            line(x1="90" y1="20" x2="90" y2="100" stroke="#333" stroke-width="1")
            rect(x="3" y="23" width="94" height="14" rx="7" fill="#1a1a2e" opacity="0.8")
            circle(cx="42" cy="50" r="7" fill="#1a1a2e")
            circle(cx="58" cy="50" r="7" fill="#1a1a2e")
            circle(cx="74" cy="30" r="7" fill="#1a1a2e")
          .chord-fingers
            span 1-1-2-3-3-1
          .chord-label F Major

    //- ── YOUSICIAN-STYLE FRETBOARD GAME ──
    .fretboard-section
      .fretboard-header
        h2 🎸 String Challenge
        p Play the string shown — microphone detects your guitar in real time!
      .fretboard-wrapper
        .fb-topbar
          .fb-left
            span.fb-multiplier#fb-multiplier 1×
            .fb-lives
              span.fb-heart#heart1 ♥
              span.fb-heart#heart2 ♥
              span.fb-heart#heart3 ♥
              span.fb-heart#heart4 ♥
              span.fb-heart#heart5 ♥
          .fb-center
            span.fb-instruction#fb-instruction Press Start to Play!
          .fb-right
            .fb-score-box
              span.fb-score-label SCORE
              span.fb-score#fb-score 0
        canvas#fretboard-canvas
        .fb-bottombar
          button#fb-pause-btn.fb-icon-btn ⏸
          .fb-progress-track
            .fb-progress-fill#fb-progress-fill
          button#fb-hand-btn.fb-icon-btn 🖐
      .fb-controls
        button#fb-start-btn.fb-start-button 🎸 Start Game
        button#fb-stop-btn.fb-stop-button(style="display:none") ⏹ Stop Game
        .fb-mic-status#fb-mic-status 🎤 Microphone not active
      .fb-string-guide
        h3 String Reference Guide
        .fb-strings-ref
          each s in [{n:'6',name:'E',note:'Low E — 82 Hz'},{n:'5',name:'A',note:'A — 110 Hz'},{n:'4',name:'D',note:'D — 147 Hz'},{n:'3',name:'G',note:'G — 196 Hz'},{n:'2',name:'B',note:'B — 247 Hz'},{n:'1',name:'E',note:'High E — 330 Hz'}]
            .fb-str-item
              span.fb-str-num= s.n
              span.fb-str-name= s.name
              span.fb-str-note= s.note

    //- ── STRING NAMING QUIZ ──
    .quiz-section
      .quiz-header
        h2 📚 String Naming Quiz
        p Test your knowledge — identify the correct string name!
      .quiz-container
        .quiz-score-bar
          .quiz-stat
            span.quiz-stat-label Score
            span.quiz-stat-value#quiz-score 0
          .quiz-stat
            span.quiz-stat-label Streak
            span.quiz-stat-value#quiz-streak 🔥 0
          .quiz-stat
            span.quiz-stat-label Best
            span.quiz-stat-value#quiz-best 0
        .quiz-question#quiz-question
          .quiz-q-label Which string is this?
          .quiz-q-number#quiz-q-number 3
          .quiz-q-sub String number
          svg#quiz-string-diagram(viewBox="0 0 260 90" width="260" height="90")
        .quiz-options#quiz-options
        .quiz-feedback#quiz-feedback
        button#quiz-start-btn.quiz-start-btn 🎮 Start Quiz

    //- ── CHORD PROGRESSION PRACTICE ──
    .progression-section
      .progression-header
        h2 🎶 Chord Progression Practice
        p Practice switching between chords in time with the beat!
      .progression-container
        .prog-controls
          .prog-control-group
            label BPM
            input#prog-bpm(type="range" min="40" max="120" value="60")
            span#prog-bpm-label 60 BPM
          .prog-control-group
            label Progression
            select#prog-select
              option(value="G-C-D-Em") G → C → D → Em (Beginner)
              option(value="Am-F-C-G") Am → F → C → G (Pop)
              option(value="E-A-D-A") E → A → D → A (Rock)
              option(value="C-G-Am-F") C → G → Am → F (Classic)
        .prog-display
          .prog-current
            span.prog-label NOW PLAYING
            span.prog-chord#prog-current-chord G
          .prog-next
            span.prog-label UP NEXT
            span.prog-chord-next#prog-next-chord C
        .prog-beats
          .prog-beat#pb1
          .prog-beat#pb2
          .prog-beat#pb3
          .prog-beat#pb4
        .prog-progress-bar
          .prog-progress-fill#prog-progress-fill
        button#prog-start-btn.prog-start-btn 🎵 Start Practice
        button#prog-stop-btn.prog-stop-btn(style="display:none") ⏹ Stop

    //- ── SCALE PRACTICE ──
    .scale-section
      .scale-header
        h2 🎵 Scale Practice
        p Learn guitar scales — follow the highlighted notes!
      .scale-container
        .scale-controls
          select#scale-select
            option(value="C") C Major
            option(value="G") G Major
            option(value="Am") A Minor
            option(value="Em") E Minor
          select#scale-speed
            option(value="slow") Slow
            option(value="medium") Medium
            option(value="fast") Fast
          button#scale-start-btn.scale-start-btn 🎵 Start Scale
          button#scale-stop-btn.scale-stop-btn(style="display:none") ⏹ Stop
        .scale-display
          .scale-note-display
            .scale-current-note#scale-current-note --
            .scale-note-label#scale-note-label Press Start
        .scale-notes-row#scale-notes-row

    //- ── RHYTHM TAPPING GAME ──
    .rhythm-section
      .rhythm-header
        h2 🥁 Rhythm Tapping Game
        p Tap the spacebar or button in time with the rhythm pattern!
      .rhythm-container
        .rhythm-score-bar
          .rhythm-stat
            span.rhythm-stat-label Score
            span.rhythm-stat-value#rhythm-score 0
          .rhythm-stat
            span.rhythm-stat-label Accuracy
            span.rhythm-stat-value#rhythm-accuracy 0%
          .rhythm-stat
            span.rhythm-stat-label Level
            span.rhythm-stat-value#rhythm-level 1
        .rhythm-pattern#rhythm-pattern
        .rhythm-feedback#rhythm-feedback
        button#rhythm-tap-btn.rhythm-tap-btn 🥁 TAP (or Spacebar)
        .rhythm-controls
          button#rhythm-start-btn.rhythm-start-btn 🎮 Start Rhythm Game
          button#rhythm-stop-btn.rhythm-stop-btn(style="display:none") ⏹ Stop

    //- ── FREE STRUM MODE ──
    .strum-section
      .strum-header
        h2 🎤 Free Strum — Chord Recogniser
        p Strum your guitar and we will try to identify the chord!
      .strum-container
        .strum-display
          .strum-chord-detected#strum-chord --
          .strum-chord-label Detected Chord
          .strum-freq-info#strum-freq-info Play your guitar...
        .strum-history
          h3 Recent Chords
          .strum-history-list#strum-history-list
            p.strum-no-history No chords detected yet
        button#strum-start-btn.strum-start-btn 🎤 Start Listening
        button#strum-stop-btn.strum-stop-btn(style="display:none") ⏹ Stop

  style.
    * { box-sizing: border-box; }
    .practice-container { max-width: 1100px; margin: 0 auto; padding: 2.5rem 2rem; }
    .practice-header { text-align: center; margin-bottom: 2.5rem; padding: 2rem; background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 20px; border: 1px solid #2d6a4f; }
    .practice-header h1 { font-size: 2.4rem; color: #ffffff; font-weight: 800; margin-bottom: 0.5rem; }
    .practice-header p { color: #52b788; font-size: 1rem; }
    .tools-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
    .tool-card { background: white; border-radius: 20px; box-shadow: 0 8px 30px rgba(0,0,0,0.1); overflow: hidden; border: 1px solid #e8f5e9; transition: transform 0.2s, box-shadow 0.2s; }
    .tool-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(45,106,79,0.15); }
    .tool-header { background: linear-gradient(135deg, #1a1a2e, #2d6a4f); padding: 1.3rem 1.5rem; display: flex; align-items: center; gap: 0.75rem; }
    .tool-icon { font-size: 1.8rem; }
    .tool-header h2 { color: white; font-size: 1.2rem; font-weight: 700; margin: 0; }
    .tool-body { padding: 1.5rem; }
    .tool-footer { background: #f0faf5; padding: 0.75rem 1.5rem; border-top: 1px solid #e8f5e9; }
    .tool-footer p { font-size: 0.82rem; color: #2d6a4f; margin: 0; font-weight: 500; }
    .bpm-display { text-align: center; background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 16px; padding: 1.5rem; margin-bottom: 1.5rem; border: 2px solid #2d6a4f; }
    #bpm-value { font-size: 4rem; font-weight: 900; color: #52b788; }
    .bpm-label { font-size: 1rem; color: #a0aec0; margin-left: 0.5rem; font-weight: 600; }
    .control-group { margin-bottom: 1.2rem; }
    .control-group label { display: block; font-weight: 700; color: #1a1a2e; margin-bottom: 0.5rem; font-size: 0.88rem; text-transform: uppercase; letter-spacing: 0.5px; }
    input[type=range] { width: 100%; accent-color: #2d6a4f; cursor: pointer; }
    .range-labels { display: flex; justify-content: space-between; font-size: 0.75rem; color: #aaa; margin-top: 4px; }
    #metro-vol-label, #tuner-vol-label { font-size: 0.85rem; color: #2d6a4f; font-weight: 700; float: right; margin-top: -1.4rem; }
    .beat-dots { display: flex; justify-content: center; gap: 1rem; margin: 1.5rem 0; }
    .dot { width: 28px; height: 28px; border-radius: 50%; background: #e8f5e9; border: 2px solid #c8e6c9; transition: all 0.05s; }
    .dot.active { background: #e63946; border-color: #e63946; box-shadow: 0 0 16px rgba(230,57,70,0.6); transform: scale(1.3); }
    .start-btn { width: 100%; background: linear-gradient(135deg, #2d6a4f, #1b4332); color: white; border: none; padding: 0.9rem; border-radius: 12px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.2s; margin-top: 0.5rem; }
    .start-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(45,106,79,0.4); }
    .start-btn.running { background: linear-gradient(135deg, #e63946, #c1121f); }
    .pitch-display { text-align: center; background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 16px; padding: 1.5rem; margin-bottom: 1.2rem; border: 2px solid #2d6a4f; }
    .pitch-note { font-size: 4rem; font-weight: 900; color: #52b788; line-height: 1; }
    .pitch-cents { font-size: 0.9rem; color: #a0aec0; margin-top: 0.3rem; }
    .pitch-indicator { margin-bottom: 1.2rem; }
    .pitch-bar { position: relative; height: 14px; background: linear-gradient(to right, #3498db, #2d6a4f, #e63946); border-radius: 7px; margin-bottom: 0.4rem; }
    .pitch-needle { position: absolute; top: -5px; left: 50%; transform: translateX(-50%); width: 4px; height: 24px; background: white; border-radius: 2px; box-shadow: 0 0 8px rgba(0,0,0,0.4); transition: left 0.1s; }
    .pitch-labels { display: flex; justify-content: space-between; font-size: 0.75rem; color: #888; font-weight: 600; }
    .pitch-status { text-align: center; font-size: 0.88rem; color: #2d6a4f; margin-bottom: 1rem; padding: 0.6rem; background: #f0faf5; border-radius: 10px; font-weight: 600; border: 1px solid #c8e6c9; }
    .tuner-hint { text-align: center; color: #2d6a4f; font-size: 0.88rem; margin-bottom: 1.2rem; background: #f0faf5; padding: 0.6rem; border-radius: 10px; font-weight: 600; border: 1px solid #c8e6c9; }
    .strings-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.6rem; margin-bottom: 1.2rem; }
