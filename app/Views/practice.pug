    function resizeCanvas() { canvas.width = canvas.parentElement.clientWidth; canvas.height = 200; }
    resizeCanvas(); window.addEventListener('resize', resizeCanvas);
    function getStringY(i) { return 20 + (i / 5) * (canvas.height - 40); }
    function drawFretboard() {
      const W = canvas.width, H = canvas.height;
      ctx.fillStyle = '#1a2a3a'; ctx.fillRect(0, 0, W, H);
      ctx.strokeStyle = 'rgba(100,120,150,0.3)'; ctx.lineWidth = 1;
      for (let i = 0; i <= 8; i++) { const x = (i / 8) * W; ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke(); }
      for (let i = 0; i < 6; i++) {
        const y = getStringY(i); const t = 1 + (5 - i) * 0.4;
        ctx.shadowColor = STRING_COLORS[i]; ctx.shadowBlur = 4; ctx.strokeStyle = STRING_COLORS[i]; ctx.lineWidth = t; ctx.globalAlpha = 0.5;
        ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
