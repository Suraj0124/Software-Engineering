        ctx.shadowColor = note.hit ? '#52b788' : STRING_COLORS[note.stringIndex]; ctx.shadowBlur = note.hit ? 20 : 8;
        ctx.fillStyle = note.hit ? '#52b788' : STRING_COLORS[note.stringIndex];
