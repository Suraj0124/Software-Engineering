    function startMetro() { if (!audioCtx) audioCtx = new AudioCtx(); const bpm = parseInt(bpmSlider.value); metroInterval = setInterval(tick, (60 / bpm) * 1000); currentBeat = 0; tick(); isRunning = true; metroBtn.textContent = '⏹ Stop'; metroBtn.classList.add('running'); }
    function stopMetro() { clearInterval(metroInterval); isRunning = false; metroBtn.textContent = '▶ Start'; metroBtn.classList.remove('running'); dots.forEach(d => d.classList.remove('active')); }
    metroBtn.addEventListener('click', () => { isRunning ? stopMetro() : startMetro(); });

    let pitchRunning = false, pitchStream = null, pitchAnalyser = null, pitchAnimFrame = null;
    const pitchBtn = document.getElementById('pitch-btn');
    const pitchNote = document.getElementById('pitch-note');
    const pitchCents = document.getElementById('pitch-cents');
    const pitchStatus = document.getElementById('pitch-status');
    const pitchNeedle = document.getElementById('pitch-needle');
    const noteStrings = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
    const guitarNotes = ['E2','A2','D3','G3','B3','E4'];
    const guitarFreqs = [82.41, 110.00, 146.83, 196.00, 246.94, 329.63];
    function frequencyToNote(freq) { return Math.round(12 * (Math.log(freq / 440) / Math.log(2))) + 69; }
    function noteToFreq(note) { return 440 * Math.pow(2, (note - 69) / 12); }
    function getNoteName(freq) { const note = frequencyToNote(freq); return noteStrings[note % 12] + Math.floor(note / 12 - 1); }
